# Copy this file to .env and fill in your values
# DO NOT commit .env - it contains secrets!

# Required
AWS_REGION=us-west-1
ECR_REPOSITORY_NAME=my-app          # ECR repository name (can be same as APP_NAME)
APP_NAME=my-app                     # Used to prefix all AWS resources
DOMAIN_NAME=api.mydomain.com        # Domain for SSL certificate

# Optional
VPC_CIDR=10.0.0.0/16
DEPLOY_MODE=full
